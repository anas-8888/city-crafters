{
  "name": "city-crafters-wallet",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "libs/*"
  ],
  "scripts": {
    "build:api": "nest build api",
    "build:worker": "nest build worker",
    "start:api": "nest start api",
    "start:worker": "nest start worker",
    "start:api:dev": "nest start api --watch",
    "start:worker:dev": "nest start worker --watch",
    "start:dev": "concurrently \"npm run start:api:dev\" \"npm run start:worker:dev\"",
    "lint": "eslint \"{src,apps,libs}/**/*.ts\"",
    "test": "jest"
  },
  "dependencies": {
    "@nestjs/bull": "^10.2.1",
    "@nestjs/schedule": "^4.1.1",
    "@nestjs/throttler": "^6.2.1",
    "@nestjs/common": "^10.0.0",
    "@nestjs/config": "^3.1.1",
    "@nestjs/core": "^10.0.0",
    "@nestjs/microservices": "^10.0.0",
    "@nestjs/platform-express": "^10.0.0",
    "@nestjs/typeorm": "^10.0.1",
    "bullmq": "^5.4.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "ioredis": "^5.3.2",
    "mysql2": "^3.9.1",
    "nest-winston": "^1.9.4",
    "reflect-metadata": "^0.1.13",
    "rxjs": "^7.8.1",
    "typeorm": "^0.3.20",
    "uuid": "^9.0.1",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.0.0",
    "@nestjs/schematics": "^10.0.0",
    "@nestjs/testing": "^10.0.0",
    "@types/node": "^20.3.1",
    "@types/uuid": "^9.0.7",
    "concurrently": "^8.2.2",
    "ts-loader": "^9.4.3",
    "ts-node": "^10.9.1",
    "typescript": "^5.1.3"
  }
}
